{
  "name": "lotto-webapp",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Lotto 6/45 webapp",
  "scripts": {
    "build": "npm run lint && npm run check:data-freshness && node scripts/smoke/smoke.mjs",
    "lint": "eslint assets proxy scripts sw.js index.html",
    "lint:fix": "eslint assets proxy scripts sw.js index.html --fix",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md,css,html}\"",
    "format:write": "prettier --write \"**/*.{js,mjs,json,md,css,html}\"",
    "sync:sw-manifest": "node scripts/generate_sw_manifest.mjs",
    "check:data-freshness": "node scripts/check_static_data_freshness.mjs",
    "test:offline": "node scripts/tests/offline_playwright.mjs",
    "test:happy": "node scripts/tests/happy_playwright.mjs",
    "test:pwa-mobile": "node scripts/tests/pwa_mobile_playwright.mjs",
    "test:sync-live": "node scripts/tests/sync_live.mjs",
    "bench:ai": "node scripts/perf/ai_eval.mjs",
    "bench:ai:full": "node scripts/perf/ai_eval.mjs --full --start 1100 --end 1209 --set-count 5 --simulation-count 5000 --lookback 20 --seed 2026"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.4.0",
    "playwright": "^1.55.0",
    "prettier": "^3.8.1"
  }
}
