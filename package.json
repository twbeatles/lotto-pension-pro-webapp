{
  "name": "lotto-pension-pro-webapp",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "로또 6/45와 연금복권720+ 통계 기반 번호 추천 웹앱",
  "scripts": {
    "build": "npm run lint && npm run check:data-freshness && npm run check:pension720 && npm run check:pension720:freshness && node scripts/smoke/smoke.mjs",
    "build:release": "npm run build && npm run check:data-freshness:strict && npm run check:lotto:official",
    "build:release:browser": "npm run build:release && npm run test:sync-live:browser:official",
    "ci:data:check": "npm run check:data-freshness:strict && npm run check:lotto:official && npm run check:pension720:freshness && npm run check:docs-data-baseline",
    "ci:data:refresh": "node scripts/refresh_ci_data.mjs",
    "ci:release": "npm run lint && npm run check:data-freshness && npm run check:pension720 && node scripts/smoke/smoke.mjs",
    "ci:browser-official": "npm run test:sync-live:browser:official",
    "lint": "eslint assets proxy scripts sw.js index.html",
    "lint:fix": "eslint assets proxy scripts sw.js index.html --fix",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md,css,html}\"",
    "format:write": "prettier --write \"**/*.{js,mjs,json,md,css,html}\"",
    "sync:sw-manifest": "node scripts/generate_sw_manifest.mjs",
    "sync:docs-data-baseline": "node scripts/update_docs_data_baseline.mjs",
    "sync:lotto": "node scripts/sync_lotto_stats.mjs",
    "sync:pension720": "node scripts/fetch_pension720_stats.mjs",
    "check:data-freshness": "node scripts/check_static_data_freshness.mjs",
    "check:data-freshness:strict": "node scripts/check_static_data_freshness.mjs --strict",
    "check:lotto:official": "node scripts/check_lotto_official_freshness.mjs",
    "check:lotto:official:scheduled": "node scripts/check_lotto_official_freshness.mjs --defer-estimated-missing",
    "check:docs-data-baseline": "node scripts/update_docs_data_baseline.mjs --check",
    "check:pension720": "node scripts/fetch_pension720_stats.mjs --check",
    "check:pension720:freshness": "node scripts/fetch_pension720_stats.mjs --check-online",
    "test:browser": "npm run test:happy && npm run test:offline && npm run test:pwa-mobile",
    "test:offline": "node scripts/tests/offline_playwright.mjs",
    "test:happy": "node scripts/tests/happy_playwright.mjs",
    "test:pwa-mobile": "node scripts/tests/pwa_mobile_playwright.mjs",
    "test:sync-live": "node scripts/tests/sync_live.mjs",
    "test:sync-live:browser": "node scripts/tests/live_data_source_playwright.mjs",
    "test:sync-live:browser:official": "node scripts/tests/live_data_source_playwright.mjs --require-official",
    "bench:ai": "node scripts/perf/ai_eval.mjs",
    "bench:ai:full": "node scripts/perf/ai_eval.mjs --full --start 1100 --end 1209 --set-count 5 --simulation-count 5000 --lookback 20 --seed 2026"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.4.0",
    "playwright": "^1.55.0",
    "prettier": "^3.8.1"
  }
}
